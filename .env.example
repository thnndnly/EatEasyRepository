# ---------- Datenbank ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eateasy
DB_USER=eateasy
DB_PASSWORD=eateasy

# ---------- Mailer (Maildev lokal) ----------
MAIL_HOST=localhost
MAIL_PORT=1025

# ---------- Ollama ----------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---------- Beleg-Scanner (Phase 11, Stretch) ----------
# Defaults passen fuer lokale Entwicklung mit docker-compose.dev.yml.
# EATEASY_RECEIPT_ENABLED=true
# TESSERACT_URL=http://localhost:8884
# Frontend-Flag (Build-Zeit, Vite): false blendet den Scan-Button aus.
# VITE_FEATURE_RECEIPT=true

# ---------- Google OAuth (Phase 12, Stretch) ----------
# Standardmaessig AUS. Zum Aktivieren eine OAuth-2.0-Client-ID (Web) aus der
# Google Cloud Console anlegen und hier setzen (Backend-Flag + Client-ID, plus
# das Vite-Frontend-Flag mit derselben Client-ID).
# EATEASY_GOOGLE_OAUTH_ENABLED=true
# GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# ---------- Externe APIs ----------
# Rezept-Import nutzt TheMealDB (gratis, kein Key noetig). Spoonacular ist nicht
# implementiert — siehe IMPLEMENTATION.md Phase 7.
# OpenFoodFacts (Barcode-Lookup) — Default reicht, nur bei Self-Hosting setzen.
# OPENFOODFACTS_URL=https://world.openfoodfacts.org
