# ---------- Datenbank ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eateasy
DB_USER=eateasy
DB_PASSWORD=eateasy

# ---------- Mailer (Maildev lokal) ----------
MAIL_HOST=localhost
MAIL_PORT=1025

# ---------- Ollama ----------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---------- Beleg-Scanner (Phase 11, Stretch) ----------
# Defaults passen fuer lokale Entwicklung mit docker-compose.dev.yml.
# EATEASY_RECEIPT_ENABLED=true
# TESSERACT_URL=http://localhost:8884
# Frontend-Flag (Build-Zeit, Vite): false blendet den Scan-Button aus.
# VITE_FEATURE_RECEIPT=true

# ---------- Externe APIs ----------
# Rezept-Import nutzt TheMealDB (gratis, kein Key noetig). Spoonacular ist nicht
# implementiert — siehe IMPLEMENTATION.md Phase 7.
# OpenFoodFacts (Barcode-Lookup) — Default reicht, nur bei Self-Hosting setzen.
# OPENFOODFACTS_URL=https://world.openfoodfacts.org
